# ── Environment template ────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored.

# Canonical site URL — used for sitemap.xml, robots.txt, canonical tags and
# Open Graph metadata. Set this to the production domain (no trailing slash).
# On Vercel this falls back to VERCEL_PROJECT_PRODUCTION_URL automatically; in
# local dev it falls back to http://localhost:3000.
#   e.g. https://www.jkk.example.co.jp
NEXT_PUBLIC_SITE_URL=""

# PostgreSQL connection string.
#  - Local (Homebrew):
#      postgresql://<user>@localhost:5432/jkk_dev?schema=public
#  - Production on Vercel — AWS RDS PostgreSQL (set in Vercel env vars):
#      postgresql://<USER>:<PASSWORD>@<AWS_RDS_ENDPOINT>:5432/<DBNAME>?schema=public&sslmode=require
#      e.g. ...@jkk-prod.abcd1234efgh.ap-northeast-1.rds.amazonaws.com:5432/jkk?schema=public&sslmode=require
#      RDS requires SSL. If you get a self-signed-certificate error, use sslmode=no-verify.
DATABASE_URL="postgresql://user@localhost:5432/jkk_dev?schema=public"

# Auth.js session secret. Generate with: openssl rand -base64 33
AUTH_SECRET=""

# Google OAuth 2.0 credentials.
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web app).
# Authorized redirect URIs:
#   dev:  http://localhost:3000/api/auth/callback/google
#   prod: https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated allowlist of emails permitted to write/edit blog posts (/manage).
# Anyone can sign in with Google, but only these emails can author posts.
ADMIN_EMAILS=""

# Official LINE channel link for the お問い合わせ buttons (友だち追加 URL).
#   e.g. https://lin.ee/xxxxxxx  or  https://line.me/R/ti/p/@your-id
NEXT_PUBLIC_LINE_URL=""

# PostHog product-analytics project key. Client token (NEXT_PUBLIC_, so it ships
# to the browser — unavoidable for client-side analytics), but kept out of
# committed source: set it here in .env (gitignored) for local dev, and in the
# Vercel project env vars for production. US cloud; events are proxied through
# /ingest (next.config.ts). Project: "Adglow".
NEXT_PUBLIC_POSTHOG_KEY=""
